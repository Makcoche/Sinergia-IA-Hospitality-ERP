# Claves de Servidor Privadas (No prefijar con VITE_)
# Tu clave de API real de Google Gemini obtenida de Google AI Studio
# Requerido para conectar la central inteligente multi-agente en vivo
GEMINI_API_KEY=

# Dirección del Backend (Para entornos distribuidos en producción)
# Configura esto en tu frontend (ej: Vercel) apuntando al servidor Express (ej: Render)
VITE_API_URL=
